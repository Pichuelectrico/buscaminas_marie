MsgStart,    HEX 0048
             HEX 0041
             HEX 0020
             HEX 0045
             HEX 004D
             HEX 0050
             HEX 0045
             HEX 005A
             HEX 0041
             HEX 0044
             HEX 004F
             HEX 0020
             HEX 0045
             HEX 004C
             HEX 0020
             HEX 004A
             HEX 0055
             HEX 0045
             HEX 0047
             HEX 004F
             DEC 0

MsgScore,    HEX 0053
             HEX 0043
             HEX 004F
             HEX 0052
             HEX 0045
             HEX 003A
             HEX 0020
             DEC 0

MsgLose,     HEX 0050
             HEX 0045
             HEX 0052
             HEX 0044
             HEX 0049
             HEX 0053
             HEX 0054
             HEX 0045
             HEX 002C
             HEX 0020
